<script>
// ── DATA LAYER ──
const DB_KEY = 'studiio_v2';

function loadDB() {
  try {
    const d = localStorage.getItem(DB_KEY);
    if (d) return JSON.parse(d);
  } catch(e) {}
  return null;
}

function saveDB() {
  localStorage.setItem(DB_KEY, JSON.stringify(db));
}

function initDB() {
  const saved = loadDB();
  if (saved) return saved;
  return {
    users: [
      { id:'u1', name:'Admin', username:'admin', password:'studio2025', role:'admin' }
    ],
    equipment: [
      { id:'e1', name:'Sony A7 III', barcode:'STU-001', category:'Camera', checkedOutBy:null, checkedOutAt:null },
      { id:'e2', name:'Rode NTG-3 Shotgun Mic', barcode:'STU-002', category:'Audio', checkedOutBy:null, checkedOutAt:null },
      { id:'e3', name:'Arri SkyPanel S30-C', barcode:'STU-003', category:'Lighting', checkedOutBy:null, checkedOutAt:null },
      { id:'e4', name:'Sachtler Fluid Head Tripod', barcode:'STU-004', category:'Tripod', checkedOutBy:null, checkedOutAt:null },
      { id:'e5', name:'Canon EF 70-200mm f/2.8', barcode:'STU-005', category:'Lens', checkedOutBy:null, checkedOutAt:null },
      { id:'e6', name:'Teleprompter Pro 17"', barcode:'STU-006', category:'Teleprompter', checkedOutBy:null, checkedOutAt:null },
      { id:'e7', name:'SmallHD Focus 7 Monitor', barcode:'STU-007', category:'Monitor', checkedOutBy:null, checkedOutAt:null },
    ],
    logs: [],
    counter: 200
  };
}

let db = initDB();
let currentUser = null;
let currentItem = null;
let logFilter = 'all';
let cameraStream = null;

// ── IDs ──
function nextId() { db.counter++; saveDB(); return 'id' + db.counter; }

// ── TOAST ──
let toastTimer;
function toast(msg, type='') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show ' + type;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2400);
}

// ── TIME ──
function timeAgo(iso) {
  if (!iso) return '';
  const d = new Date(iso), now = Date.now(), diff = now - d;
  if (diff < 60000) return 'just now';
  if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
  if (diff < 86400000) return Math.floor(diff/3600000) + 'h ago';
  return d.toLocaleDateString('en-US',{month:'short',day:'numeric'}) + ' · ' + d.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'});
}

// ── LOGIN / LOGOUT ──
function doLogin() {
  const u = document.getElementById('l-user').value.trim();
  const p = document.getElementById('l-pass').value;
  db = initDB();
  const user = db.users.find(x => x.username === u && x.password === p);
  if (!user) { document.getElementById('login-err').textContent = 'Incorrect username or password.'; return; }
  currentUser = user;
  document.getElementById('login-err').textContent = '';
  document.getElementById('l-user').value = '';
  document.getElementById('l-pass').value = '';
  document.querySelectorAll('.admin-only').forEach(el => {
    el.style.display = user.role === 'admin' ? '' : 'none';
  });
  showScreen('screen-home');
  refreshHome();
}

function doLogout() {
  stopCamera();
  currentUser = null;
  currentItem = null;
  document.querySelectorAll('.screen').forEach(s => { s.classList.add('hidden'); s.classList.remove('slide-left'); });
  document.getElementById('screen-login').classList.remove('hidden');
}

// ── SCREEN NAV ──
let currentScreen = 'screen-login';

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => {
    if (s.id === id) { s.classList.remove('hidden'); s.classList.remove('slide-left'); }
    else if (s.id === currentScreen) { s.classList.add('slide-left'); setTimeout(() => s.classList.add('hidden'), 300); }
    else { s.classList.add('hidden'); s.classList.remove('slide-left'); }
  });
  currentScreen = id;
}

function navTo(name) {
  const map = { home:'screen-home', scanner:'screen-scanner', logs:'screen-logs', admin:'screen-admin' };
  const id = map[name];
  if (!id) return;
  stopCamera();
  showScreen(id);
  // update nav
  document.querySelectorAll('.bottom-nav .nav-item').forEach((el, i) => {
    el.classList.remove('active');
  });
  const navItems = document.querySelectorAll('#screen-home .nav-item');
  const navMap = ['home','scanner','logs','admin'];
  navItems.forEach(el => { if (el.onclick && el.onclick.toString().includes(name)) el.classList.add('active'); });
  if (name === 'home') refreshHome();
  if (name === 'logs') renderLogs();
  if (name === 'admin') { renderAdminUsers(); renderAdminEquip(); renderAdminAllLogs(); }
  if (name === 'scanner') { currentItem = null; document.getElementById('item-card').classList.remove('visible'); document.getElementById('bc-input').value = ''; }
}

// ── HOME ──
function refreshHome() {
  db = initDB();
  document.getElementById('home-name').textContent = currentUser.name;
  const total = db.equipment.length;
  const out = db.equipment.filter(e => e.checkedOutBy).length;
  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-avail').textContent = total - out;
  document.getElementById('stat-out').textContent = out;
  // my items
  const mine = db.equipment.filter(e => e.checkedOutBy === currentUser.id);
  const wrap = document.getElementById('my-items-wrap');
  if (mine.length > 0) {
    wrap.style.display = '';
    document.getElementById('my-items-list').innerHTML = mine.map(e => `
      <div class="my-item-chip">
        <div><div class="mic-name">${e.name}</div><div class="mic-barcode">${e.barcode}</div></div>
        <span class="badge badge-out">Out</span>
      </div>`).join('');
  } else { wrap.style.display = 'none'; }
}

// ── SCANNER ──
function onBarcodeInput(val) {
  if (val.length >= 2) {
    db = initDB();
    const item = db.equipment.find(e => e.barcode.toLowerCase().startsWith(val.toLowerCase()) || e.barcode.toLowerCase() === val.toLowerCase());
    if (item) { currentItem = item; renderItemCard(item); }
    else { document.getElementById('item-card').classList.remove('visible'); }
  } else {
    document.getElementById('item-card').classList.remove('visible');
    currentItem = null;
  }
}

function lookupBarcode() {
  db = initDB();
  const val = document.getElementById('bc-input').value.trim().toUpperCase();
  if (!val) return;
  const item = db.equipment.find(e => e.barcode.toUpperCase() === val);
  if (!item) { toast('Barcode not found', 'error'); document.getElementById('item-card').classList.remove('visible'); return; }
  currentItem = item;
  renderItemCard(item);
}

function renderItemCard(item) {
  document.getElementById('ic-name').textContent = item.name;
  document.getElementById('ic-barcode').textContent = item.barcode;
  document.getElementById('ic-cat').textContent = item.category;
  const sb = document.getElementById('ic-status-badge');
  const ab = document.getElementById('ic-action-btn');
  const who = document.getElementById('ic-who');
  if (item.checkedOutBy) {
    const u = db.users.find(u => u.id === item.checkedOutBy);
    sb.textContent = 'Checked Out'; sb.className = 'badge badge-out';
    who.innerHTML = `Checked out by <strong>${u ? u.name : 'Unknown'}</strong> · ${timeAgo(item.checkedOutAt)}`;
    ab.textContent = 'Return Item';
    ab.className = 'action-btn btn-return-action';
  } else {
    sb.textContent = 'Available'; sb.className = 'badge badge-available';
    who.innerHTML = '';
    ab.textContent = 'Check Out to Me';
    ab.className = 'action-btn btn-checkout-action';
  }
  document.getElementById('item-card').classList.add('visible');
}

function doAction() {
  if (!currentItem) return;
  db = initDB();
  const item = db.equipment.find(e => e.id === currentItem.id);
  if (!item) return;
  const now = new Date().toISOString();
  if (item.checkedOutBy) {
    if (item.checkedOutBy !== currentUser.id && currentUser.role !== 'admin') {
      toast('Only the borrower or an admin can return this item', 'error'); return;
    }
    db.logs.unshift({ id: nextId(), itemId: item.id, itemName: item.name, barcode: item.barcode, category: item.category, userId: currentUser.id, userName: currentUser.name, action: 'return', time: now });
    item.checkedOutBy = null; item.checkedOutAt = null;
    toast('Item returned ✓', 'success');
  } else {
    db.logs.unshift({ id: nextId(), itemId: item.id, itemName: item.name, barcode: item.barcode, category: item.category, userId: currentUser.id, userName: currentUser.name, action: 'checkout', time: now });
    item.checkedOutBy = currentUser.id; item.checkedOutAt = now;
    toast('Checked out to you ✓', 'success');
  }
  saveDB();
  currentItem = item;
  renderItemCard(item);
}

// ── CAMERA ──
function toggleCamera() {
  if (cameraStream) { stopCamera(); return; }
  const vid = document.getElementById('scan-video');
  const btn = document.getElementById('cam-btn');
  const laser = document.getElementById('scan-laser');
  const hint = document.getElementById('vf-hint');
  if (!navigator.mediaDevices?.getUserMedia) { toast('Camera not supported — use manual entry', 'error'); return; }
  navigator.mediaDevices.getUserMedia({ video: { facingMode: { ideal: 'environment' }, width: { ideal: 1280 } } })
    .then(stream => {
      cameraStream = stream;
      vid.srcObject = stream; vid.style.display = 'block';
      document.getElementById('vf-overlay').style.pointerEvents = 'none';
      laser.style.display = 'block';
      hint.textContent = 'Camera active — use manual entry below';
      btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg> Stop Camera`;
    })
    .catch(() => toast('Camera permission denied — use manual entry', 'error'));
}

function stopCamera() {
  if (!cameraStream) return;
  cameraStream.getTracks().forEach(t => t.stop()); cameraStream = null;
  const vid = document.getElementById('scan-video');
  vid.srcObject = null; vid.style.display = 'none';
  document.getElementById('scan-laser').style.display = 'none';
  document.getElementById('vf-hint').textContent = 'Tap below to open camera';
  const btn = document.getElementById('cam-btn');
  btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Open Camera Scanner`;
}

// ── LOGS ──
function setFilter(f, el) {
  logFilter = f;
  document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  renderLogs();
}

function renderLogs() {
  db = initDB();
  let logs = [...db.logs];
  if (logFilter === 'out') logs = logs.filter(l => l.action === 'checkout');
  else if (logFilter === 'in') logs = logs.filter(l => l.action === 'return');
  else if (logFilter === 'mine') logs = logs.filter(l => l.userId === currentUser.id);
  const el = document.getElementById('logs-list');
  if (logs.length === 0) { el.innerHTML = '<div class="empty">No logs match this filter.</div>'; return; }
  el.innerHTML = logs.map(l => `
    <div class="log-row">
      <div class="log-row-top">
        <div class="log-row-name">${l.itemName}</div>
        <span class="badge ${l.action === 'checkout' ? 'badge-out' : 'badge-available'}">${l.action === 'checkout' ? 'Out' : 'In'}</span>
      </div>
      <div class="log-row-bottom">
        <div class="log-row-user">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/></svg>
          ${l.userName}
          <span style="font-family:var(--mono);font-size:11px;color:var(--text3);margin-left:4px;">${l.barcode}</span>
        </div>
        <div class="log-row-time">${timeAgo(l.time)}</div>
      </div>
    </div>`).join('');
}

// ── ADMIN ──
function adminTab(name, el) {
  document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('panel-'+name).classList.add('active');
}

function renderAdminUsers() {
  db = initDB();
  const el = document.getElementById('admin-users-list');
  el.innerHTML = db.users.map(u => `
    <div class="user-row">
      <div class="avatar">${u.name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase()}</div>
      <div class="user-info">
        <div class="user-name">${u.name}</div>
        <div class="user-meta">@${u.username}</div>
      </div>
      <span class="role-badge ${u.role === 'admin' ? 'role-admin' : 'role-student'}">${u.role}</span>
      ${u.id !== 'u1' ? `<button class="icon-btn del" onclick="deleteUser('${u.id}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></button>` : ''}
    </div>`).join('');
}

function renderAdminEquip() {
  db = initDB();
  const el = document.getElementById('admin-equip-list');
  el.innerHTML = db.equipment.map(e => `
    <div class="equip-row">
      <div class="equip-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg></div>
      <div class="equip-info">
        <div class="equip-name">${e.name}</div>
        <div class="equip-meta">${e.barcode} · ${e.category}</div>
      </div>
      <span class="badge ${e.checkedOutBy ? 'badge-out' : 'badge-available'}" style="flex-shrink:0;margin-right:6px;">${e.checkedOutBy ? 'Out' : 'In'}</span>
      <button class="icon-btn del" onclick="deleteEquip('${e.id}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></button>
    </div>`).join('');
}

function renderAdminAllLogs() {
  db = initDB();
  const el = document.getElementById('admin-all-logs');
  const logs = db.logs;
  if (logs.length === 0) { el.innerHTML = '<div class="empty">No activity recorded yet.</div>'; return; }
  el.innerHTML = logs.map(l => `
    <div class="log-row">
      <div class="log-row-top">
        <div class="log-row-name">${l.itemName}</div>
        <span class="badge ${l.action === 'checkout' ? 'badge-out' : 'badge-available'}">${l.action === 'checkout' ? 'Out' : 'In'}</span>
      </div>
      <div class="log-row-bottom">
        <div class="log-row-user">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/></svg>
          ${l.userName}
          <span style="font-family:var(--mono);font-size:11px;color:var(--text3);margin-left:4px;">${l.barcode}</span>
        </div>
        <div class="log-row-time">${timeAgo(l.time)}</div>
      </div>
    </div>`).join('');
}

// ── USER MGMT ──
function openSheet(id) { document.getElementById(id).classList.add('open'); }
function closeSheet(id) { document.getElementById(id).classList.remove('open'); }
function sheetOverlayClick(e, id) { if (e.target === e.currentTarget) closeSheet(id); }

function createUser() {
  const name = document.getElementById('nu-name').value.trim();
  const username = document.getElementById('nu-user').value.trim().toLowerCase();
  const pass = document.getElementById('nu-pass').value;
  const role = document.getElementById('nu-role').value;
  const err = document.getElementById('nu-err');
  if (!name || !username || !pass) { err.textContent = 'All fields are required.'; return; }
  db = initDB();
  if (db.users.find(u => u.username === username)) { err.textContent = 'Username is already taken.'; return; }
  db.users.push({ id: nextId(), name, username, password: pass, role });
  saveDB();
  err.textContent = '';
  document.getElementById('nu-name').value = '';
  document.getElementById('nu-user').value = '';
  document.getElementById('nu-pass').value = '';
  closeSheet('sheet-new-user');
  renderAdminUsers();
  toast(`Account created for ${name}`, 'success');
}

function deleteUser(id) {
  if (!confirm('Remove this user?')) return;
  db = initDB();
  db.users = db.users.filter(u => u.id !== id);
  saveDB();
  renderAdminUsers();
  toast('User removed');
}

// ── EQUIPMENT MGMT ──
function addEquipment() {
  const name = document.getElementById('eq-name').value.trim();
  const barcode = document.getElementById('eq-bc').value.trim().toUpperCase();
  const category = document.getElementById('eq-cat').value;
  if (!name || !barcode) { toast('Name and barcode are required', 'error'); return; }
  db = initDB();
  if (db.equipment.find(e => e.barcode.toUpperCase() === barcode)) { toast('That barcode already exists', 'error'); return; }
  db.equipment.push({ id: nextId(), name, barcode, category, checkedOutBy: null, checkedOutAt: null });
  saveDB();
  document.getElementById('eq-name').value = '';
  document.getElementById('eq-bc').value = '';
  renderAdminEquip();
  refreshHome();
  toast(`${name} added ✓`, 'success');
}

function deleteEquip(id) {
  if (!confirm('Remove this item from inventory?')) return;
  db = initDB();
  db.equipment = db.equipment.filter(e => e.id !== id);
  saveDB();
  renderAdminEquip();
  refreshHome();
  toast('Equipment removed');
}

// ── KEYBOARD ──
document.getElementById('l-pass').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
document.getElementById('l-user').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('l-pass').focus(); });
</script>
</body>
